    "./legal": {
      "import": "./build/legal/index.js",
      "types": "./build/legal/index.d.ts"
    },
    "./media": {
      "import": "./build/media/index.js",
      "types": "./build/media/index.d.ts"
    },
    "./notifications": {
      "import": "./build/notifications/index.js",
      "types": "./build/notifications/index.d.ts"
    },
    "./react": {
      "import": "./build/react/index.js",
      "types": "./build/react/index.d.ts"
    },
    "./server": {
      "import": "./build/server/index.js",
      "types": "./build/server/index.d.ts"
    },
    "./social": {
      "import": "./build/social/index.js",
      "types": "./build/social/index.d.ts"
    },
    "./storage": {
      "import": "./build/storage/index.js",
      "types": "./build/storage/index.d.ts"
    }
  },
  "files": [
    "build"
  ],
  "scripts": {
    "dev": "bun run build --watch",
    "build": "bun scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "format": "biome format --write",
    "knip": "knip-bun",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "prepublishOnly": "bun run build",
    "prepare": "husky",
    "changeset": "changeset",
    "release": "bun run build && changeset publish"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "jose": "^6.1.3"
  },
  "peerDependencies": {
