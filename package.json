{
  "_todo": "Revisit package name — @omnidotdev/providers may not reflect the package's scope (shared auth, billing, events, storage, flags, notifications SDK)",
  "name": "@omnidotdev/providers",
  "version": "0.1.0",
  "description": "Shared auth, authorization, billing, events, feature flags, notifications, storage, and API key providers for the Omni ecosystem",
  "license": "Apache-2.0",
  "homepage": "https://github.com/omnidotdev/providers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omnidotdev/providers.git"
  },
  "bugs": "https://github.com/omnidotdev/providers/issues",
  "type": "module",
  "main": "./build/index.js",
  "module": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
